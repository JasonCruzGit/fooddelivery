PORT=4000
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Messenger configuration:
# deeplink = redirect customer with prefilled message
# api = send directly with Graph API (requires recipient id and page token)
MESSENGER_MODE=deeplink
MESSENGER_PAGE_USERNAME=yourrestaurantpage
MESSENGER_PAGE_URL=
MESSENGER_PAGE_ACCESS_TOKEN=
MESSENGER_RECIPIENT_ID=

# Optional: Supabase backup logging (recommended for production)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
